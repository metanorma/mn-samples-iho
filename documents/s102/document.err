	<clause id="_logical_consistency" obligation="normative"><title>Logical Consistency</title><clause id="_conceptual_consistency" obligation="normative">
	<title>Conceptual Consistency</title>
	<p id="_ce4f3edf-d4f6-48d8-b8b8-ec22191d2f8c">The conceptual consistency of S-102 grids is maintained through this and related specifications which are conceptually consistent with the accepted standards.</p>
	</clause>
	<clause id="_domain_consistency" obligation="normative">
